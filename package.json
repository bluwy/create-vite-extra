{
  "name": "create-vite-extra",
  "version": "4.2.0",
  "description": "Extra Vite templates",
  "type": "module",
  "license": "(MIT OR CC0-1.0)",
  "author": "Bjorn Lu",
  "bin": {
    "create-vite-extra": "./dist/index.js"
  },
  "exports": "./dist/index.js",
  "files": [
    "index.js",
    "template-*",
    "!template-*/dist",
    "!template-*/node_modules",
    "!template-*/package-lock.json",
    "!template-*/pnpm-lock.yaml",
    "!template-*/deno.lock"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluwy/create-vite-extra.git"
  },
  "bugs": {
    "url": "https://github.com/bluwy/create-vite-extra/issues"
  },
  "homepage": "https://github.com/bluwy/create-vite-extra#readme",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "typecheck": "tsc",
    "update-deps": "pnpm update -r --latest && node scripts/update-deno-deps.ts"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "minimist": "^1.2.8",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/prompts": "^2.4.9",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.7",
    "typescript": "~6.0.2"
  }
}
